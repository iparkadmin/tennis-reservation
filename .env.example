# ===========================================
# Supabase Configuration
# ===========================================
# SupabaseダッシュボードのSettings > APIから取得
# https://supabase.com/dashboard/project/[YOUR_PROJECT_ID]/settings/api

# Project URL (公開可能)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (公開可能 - RLSで保護されている)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (秘密 - サーバーサイドのみで使用)
# ※ 絶対にクライアントサイドに公開しないこと
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Management API で SQL 実行する場合（run-sql-via-api.js）:
# SUPABASE_ACCESS_TOKEN=sbp_xxx  # https://supabase.com/dashboard/account/tokens で取得

# ===========================================
# App Configuration
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
